# Resend API key — generate at https://resend.com/api-keys
RESEND_API_KEY=

# Inbox that receives contact submissions (your private email is fine).
# With email forwarding on nefrod.no, you can also use post@nefrod.no
# and let your registrar deliver it to your real inbox.
CONTACT_TO_EMAIL=

# Optional — sender address. Defaults to onboarding@resend.dev (Resend's
# shared sender; works immediately, no DNS required).
# Once you verify nefrod.no in Resend, change to e.g. noreply@nefrod.no.
CONTACT_FROM_EMAIL=

# Optional — display name on the sender. Defaults to "Nordic Entrepreneur Forum Rød".
CONTACT_FROM_NAME=

# Optional — set to "true" to also email the visitor a confirmation.
# Requires CONTACT_FROM_EMAIL to be on a domain verified in Resend.
CONTACT_AUTOREPLY=

# Optional — public Reply-To address shown to visitors on the autoreply.
# This is what visitors see if they hit "Reply" on the autoreply email. Use
# a branded forwarding address (e.g. post@nefrod.no) so your private inbox
# (CONTACT_TO_EMAIL) is never exposed in their email client.
CONTACT_REPLY_TO=
